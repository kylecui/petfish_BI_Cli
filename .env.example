# petfish_BI_Cli environment variables
# Copy this file to .env and fill in your keys
# .env is gitignored and will NEVER be committed

# Model provider keys (at least one required for real queries)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Optional: custom base URLs (e.g. for proxies or self-hosted)
OPENAI_BASE_URL=
ANTHROPIC_BASE_URL=

# Optional: override model config (bi_cli.yml takes precedence over these)
BI_CLI_MODEL_PROVIDER=openai
BI_CLI_MODEL_NAME=gpt-4o
