{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "skill": {
      "petfish-style-rewriter": "allow",
      "fish-trail": "allow"
    }
  },
  "plugin": [
    [
      ".opencode/plugin/system-prompt-rules.ts",
      {
        "mode": "all"
      }
    ],
    [
      ".opencode/plugin/system-prompt-context-inject.ts",
      {
        "maxTopics": 5,
        "maxSummaryLen": 200
      }
    ]
  ],
  "mcp": {
    "context-state": {
      "type": "local",
      "command": [
        "uv",
        "run",
        "python",
        ".opencode/skills/fish-trail/mcp/context-state/server.py"
      ]
    }
  }
}
