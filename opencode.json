{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "skill": {
      "petfish-style-rewriter": "allow",
      "fish-trail": "allow",
      "petfish-companion": "allow",
      "marketplace-connector": "allow",
      "skill-author": "allow",
      "skill-lint": "allow",
      "repo-skill-miner": "allow",
      "skill-security-auditor": "allow",
      "quality-gate": "allow",
      "skill-description-optimizer": "allow",
      "skill-trigger-evaluator": "allow",
      "skill-usage-tracker": "allow",
      "ppt-reader": "allow",
      "ppt-writer": "allow"
    }
  },
  "plugin": [
    [
      ".opencode/plugin/system-prompt-rules.ts",
      {
        "mode": "all"
      }
    ],
    [
      ".opencode/plugin/system-prompt-context-inject.ts",
      {
        "maxTopics": 5,
        "maxSummaryLen": 200,
        "detectionMode": "disk",
        "reflectiveBriefEnabled": true
      }
    ]
  ],
  "mcp": {
    "context-state": {
      "type": "local",
      "command": [
        "uv",
        "run",
        "python",
        ".opencode/skills/fish-trail/mcp/context-state/server.py"
      ]
    },
    "skill-registry": {
      "type": "local",
      "command": [
        "uv",
        "run",
        "python",
        ".opencode/mcp/skill-registry/server.py"
      ]
    },
    "usage-cost": {
      "type": "local",
      "command": [
        "uv",
        "run",
        "python",
        ".opencode/mcp/usage-cost/server.py"
      ]
    }
  }
}
